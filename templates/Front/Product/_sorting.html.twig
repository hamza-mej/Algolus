{% set routeName = app.request.attributes.get('_route') %}
{% set routeParams = app.request.attributes.get('_route_params')|default({}) %}
{% set queryParams = app.request.query.all %}
{% set baseParams = routeParams|merge(queryParams)|merge({'sort': 'p.productPrice', 'page': 1}) %}
{% set ascHref = path(routeName, baseParams|merge({'direction': 'asc'})) %}
{% set descHref = path(routeName, baseParams|merge({'direction': 'desc'})) %}
{% set currentSort = app.request.query.get('sort')|default('') %}
{% set currentDirection = app.request.query.get('direction')|default('')|lower %}
{% set isPriceSort = currentSort == 'p.productPrice' %}
{% set ascActive = (not isPriceSort) or (isPriceSort and currentDirection != 'desc') %}
{% set descActive = isPriceSort and currentDirection == 'desc' %}

<span class="price-sort-btn">
    <span class="price-sort-label">Price</span>
    <span class="price-sort-arrows" aria-hidden="true">
        <a href="{{ ascHref }}" class="price-arrow-link price-arrow-up-link{{ ascActive ? ' is-active' : '' }}" aria-label="Sort price low to high"></a>
        <a href="{{ descHref }}" class="price-arrow-link price-arrow-down-link{{ descActive ? ' is-active' : '' }}" aria-label="Sort price high to low"></a>
    </span>
</span>
